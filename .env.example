# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL="file:./prisma/dev.db"

# Admin Authentication (REQUIRED for security)
# Change this to a strong random secret
ADMIN_SECRET="your-super-secret-admin-password-change-this"

# WhatsApp Number (for lead notifications)
NEXT_PUBLIC_WA_NUMBER="6281234567890"

# Company Email (for lead notifications)
NEXT_PUBLIC_COMPANY_EMAIL="your-email@example.com"

# Resend API Key (for email notifications)
RESEND_API_KEY="re_your_resend_api_key"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL="XXXXXXXXXX"

# AdSense (optional)
NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXX"

# AI Services (optional)
OPENAI_API_KEY="sk-your-openai-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"

# Image Generation (optional)
REPLICATE_API_TOKEN="your-replicate-token"

# Vercel Analytics (enabled by default if using Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
